# Copy to .env — `make dev` works with these defaults out of the box.
# NEVER commit .env. Real secrets live in the deployment platform's secret store.

ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Auth — generate a real one for staging/prod: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-secret-change-me

# AI (M3+) — paste your key here, never commit it (.env is gitignored)
ANTHROPIC_API_KEY=

# Overridden inside Docker Compose (service hostnames); these are for running natively.
DATABASE_URL=postgresql+asyncpg://vaultly:vaultly@localhost:5432/vaultly
REDIS_URL=redis://localhost:6379/0

# Object storage — MinIO locally, S3 in production
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=vaultly-documents
S3_ACCESS_KEY=vaultly
S3_SECRET_KEY=vaultly-local

# Email — Mailpit locally (UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=reminders@vaultly.local

# Billing (M9) — paste test-mode keys here, never commit them (.env is gitignored)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_FAMILY=

# Observability (M10) — error tracking. Empty = disabled, zero behavior change.
SENTRY_DSN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=
